   "source": [
    "# p-Werte gegen TSK-0 berechnen\n",
    "final_report[\"p_values_auc\"] = {}\n",
    "final_report[\"p_values_f1\"] = {}\n",
    "\n",
    "ref_auc = final_report[\"metrics\"][\"TSK-1\"]['auc']\n",
    "ref_f1 = final_report[\"metrics\"][\"TSK-1\"]['f1']\n",
    "print(f\"Referenz TSK-1 hat {len(ref_auc)} Werte.\")\n",
    "\n",
    "for name in model_names:\n",
    "    if name != \"TSK-1\":\n",
    "        current_auc = final_report[\"metrics\"][name]['auc']\n",
    "\n",
    "        # Check, ob die Längen übereinstimmen\n",
    "        if len(current_auc) == len(ref_auc) and len(ref_auc) > 0:\n",
    "            _, p = stats.ttest_rel(ref_auc, current_auc)\n",
    "            final_report[\"p_values_auc\"][name] = p\n",
    "        else:\n",
    "            print(f\"WARNUNG: {name} hat nur {len(current_auc)} Werte. t-Test nicht möglich.\")\n",
    "            final_report[\"p_values_auc\"][name] = np.nan\n",
    "\n",
    "    if name != \"TSK-1\":\n",
    "        current_f1 = final_report[\"metrics\"][name]['f1']\n",
    "\n",
    "        # Check, ob die Längen übereinstimmen\n",
    "        if len(current_f1) == len(ref_f1) and len(ref_f1) > 0:\n",
    "            _, p = stats.ttest_rel(ref_f1, current_f1)\n",
    "            final_report[\"p_values_f1\"][name] = p\n",
    "        else:\n",
    "            print(f\"WARNUNG: {name} hat nur {len(current_f1)} Werte. t-Test nicht möglich.\")\n",
    "            final_report[\"p_values_f1\"][name] = np.nan\n",
    "\n",
    "# Tabellarische Übersicht generieren\n",
    "summary = []\n",
    "for name in model_names:\n",
    "    m = final_report[\"metrics\"][name]\n",
    "\n",
    "    # Berechne Mittelwerte nur, wenn Daten vorhanden sind\n",
    "    avg_auc = np.mean(m['auc']) if len(m['auc']) > 0 else 0\n",
    "    std_auc = np.std(m['auc']) if len(m['auc']) > 0 else 0\n",
    "    avg_f1 = np.mean(m['f1']) if len(m['f1']) > 0 else 0\n",
    "\n",
    "    summary.append({\n",
    "        \"Model\": name,\n",
    "        \"Mean AUC\": f\"{avg_auc:.4f}\",\n",
    "        \"Std AUC\": f\"{std_auc:.4f}\",\n",
    "        \"Mean F1\": f\"{avg_f1:.4f}\",\n",
    "        \"p-val_auc vs TSK-1\": f\"{final_report['p_values_auc'].get(name, '--'):.4f}\" if not pd.isna(final_report['p_values_auc'].get(name)) else \"N/A\",\n",
    "        \"p-val_f1 vs TSK-1\": f\"{final_report['p_values_f1'].get(name, '--'):.4f}\" if not pd.isna(final_report['p_values_f1'].get(name)) else \"N/A\"\n",
    "    })\n",
    "\n",
    "results_df = pd.DataFrame(summary)\n",
    "display(results_df)\n",
    "\n",
    "print(\"\\n--- BEST PARAMETERS FOR REPRODUCIBILITY ---\")\n",
    "for model, params in final_report[\"best_params\"].items():\n",
    "    print(f\"{model}: {params}\")\n",
    "\n",
    "summary = []\n",
    "\n",
    "for name in model_names:\n",
    "    m = final_report[\"metrics\"][name]\n",
    "    summary.append({\n",
    "        \"Model\": name,\n",
    "        \"Mean AUC\": np.mean(m['auc']),\n",
    "        \"Mean F1\": np.mean(m['f1']),\n",
    "        \"P@10%\": np.mean(m['p_at_k']), # Präzision in den Top 10%\n",
    "        \"R@10%\": np.mean(m['r_at_k']), # Wie viel % aller Kartelle in den Top 10% gefunden?\n",
    "        \"p-val_auc vs TSK-1\": f\"{final_report['p_values_auc'].get(name, '--'):.4f}\" if name != \"TSK-1\" else \"--\",\n",
    "        \"p-val_f1 vs TSK-1\": f\"{final_report['p_values_f1'].get(name, '--'):.4f}\" if name != \"TSK-1\" else \"--\"\n",
    "    })\n",
    "\n",
    "results_df = pd.DataFrame(summary)\n",
    "display(results_df)\n"
