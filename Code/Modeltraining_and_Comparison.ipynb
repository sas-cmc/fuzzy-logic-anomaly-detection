   "cell_type": "markdown",
   "source": "# 10-Fold Cross-Validation",
   "id": "f73b669e17d724fa"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-27T15:41:05.008049Z",
     "start_time": "2026-03-27T15:40:54.033873Z"
    }
   },
   "cell_type": "code",
   "source": [
    "from sklearn.metrics import roc_auc_score, f1_score, precision_score, recall_score\n",
    "import numpy as np\n",
    "\n",
    "print(\"Erstelle Architektur für Vergleich\")\n",
    "# 1. Setup\n",
    "skf = StratifiedKFold(n_splits=10, shuffle=True, random_state=2000)\n",
    "model_names = [\"TSK-0\", \"TSK-1\", \"Mamdani\", \"Random Forest\", \"XGBoost\", \"SVM\"]\n",
    "metrics_list = ['auc', 'f1', 'prec', 'rec', 'p_at_k', 'r_at_k']\n",
    "\n",
    "# Initialisierung des Reports (nur einmal nötig)\n",
    "for name in model_names:\n",
    "    final_report[\"metrics\"][name] = {m: [] for m in metrics_list}\n",
    "\n",
    "print(\"*\"*100)\n",
    "pprint.pprint(final_report)\n",
    "print(\"*\"*100)\n",
    "\n",
    "print(\"Starte finale Evaluation (10-Fold CV)...\")\n",
    "\n",
    "tsk0_weights_collector = {f\"f{i}\": [] for i in range(1, 8)}\n",
    "tsk1_coeffs_collector = {f\"f{i}\": [] for i in range(1, 8)}\n",
    "\n",
    "for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n",
    "    print(f\"Verarbeite Fold {fold+1}/10...\", end=\"\\r\")\n",
    "\n",
    "    X_f_train, X_f_val = X.iloc[train_idx], X.iloc[val_idx]\n",
    "    y_f_train, y_f_val = y.iloc[train_idx], y.iloc[val_idx]\n",
    "\n",
    "    # Trainings-DF für die datengetriebene TSK-Gewichtung\n",
    "    train_df = X_f_train.copy()\n",
    "    train_df['cartel'] = y_f_train\n",
    "\n",
    "    # --- A. TSK SETUP (SIMPFUL) ---\n",
    "    # Wir definieren die Subsets basierend auf den Experten-Regeln\n",
    "    subsets = [\n",
    "        train_df[(train_df['cv'] <= 0.06) & (train_df['spread'] <= 0.20)],\n",
    "        train_df[(train_df['cv'] <= 0.06) & (train_df['diffp'] >= 0.02)],\n",
    "        train_df[(train_df['cv'] <= 0.06)],\n",
    "        train_df[(train_df['cv'] <= 0.06) & (train_df['rd'] >= 2.5)],\n",
    "        train_df[(train_df['rd'] >= 2.5) & (train_df['skew'] <= 0.2)],\n",
    "        train_df[(train_df['cv'] >= 0.05) & (train_df['spread'] >= 0.15)],\n",
    "        train_df[(train_df['rd'] <= 3.5) & (train_df['spread'] <= 0.20)]\n",
    "    ]\n",
    "\n",
    "    FS0 = sf.FuzzySystem(verbose=0); setup_simpful_vars(FS0)\n",
    "    FS1 = sf.FuzzySystem(verbose=0); setup_simpful_vars(FS1)\n",
    "\n",
    "\n",
    "    for i, sub in enumerate(subsets, 1):\n",
    "        # TSK-0: Konstante (Mittelwert der Zielvariable im Subset)\n",
    "        val0 = sub['cartel'].mean() if not sub.empty else 0.5\n",
    "        FS0.set_output_function(f\"f{i}\", str(val0))\n",
    "        tsk0_weights_collector[f\"f{i}\"].append(val0)\n",
    "\n",
    "        # TSK-1: Lineare Gleichung (Nutzt die optimierte Funktion aus der vorherigen Zelle)\n",
    "        eq1 = get_tsk1_equation(sub, features_fis)\n",
    "        FS1.set_output_function(f\"f{i}\", eq1)\n",
    "\n",
    "    FS0.add_rules(tsk_rules); FS1.add_rules(tsk_rules)\n",
    "\n",
    "    # --- B. INFERENZ-SCHLEIFE (Fuzzy & ML) ---\n",
    "    scores_dict = {name: [] for name in model_names}\n",
    "\n",
    "    # 1. Fuzzy Inferenz (Row-by-Row)\n",
    "    for _, row in X_f_val.iterrows():\n",
    "        # TSK Inferenz\n",
    "        for fs, name in [(FS0, \"TSK-0\"), (FS1, \"TSK-1\")]:\n",
    "            for f in features_fis: fs.set_variable(f, row[f])\n",
    "            res = fs.Sugeno_inference(['suspiciousness']).get('suspiciousness', 0.5)\n",
    "            scores_dict[name].append(res)\n",
    "\n",
    "        # Mamdani Inferenz (skfuzzy)\n",
    "        try:\n",
    "            for f in features_fis:\n",
    "                mamdani_sim.input[f] = row[f]\n",
    "            mamdani_sim.compute()\n",
    "            scores_dict[\"Mamdani\"].append(mamdani_sim.output['Verdächtigkeitsscore'])\n",
    "        except:\n",
    "            scores_dict[\"Mamdani\"].append(50.0)\n",
    "\n",
    "    # 2. ML Inferenz (Batch)\n",
    "    ml_models = [\n",
    "        (\"Random Forest\", rf_search.best_estimator_),\n",
    "        (\"XGBoost\", xgb_search.best_estimator_),\n",
    "        (\"SVM\", svm_search.best_estimator_)\n",
    "    ]\n",
    "    for name, model in ml_models:\n",
    "        model.fit(X_f_train, y_f_train)\n",
    "        scores_dict[name] = model.predict_proba(X_f_val)[:, 1]\n",
    "\n",
    "    # --- C. METRIKEN BERECHNEN & SPEICHERN ---\n",
    "    k_val = max(1, int(len(y_f_val) * 0.10)) # Top 10%\n",
    "\n",
    "    for name in model_names:\n",
    "        s = np.array(scores_dict[name])\n",
    "        # Threshold-Anpassung: Mamdani skaliert oft 0-100, andere 0-1\n",
    "        thres = 50.0 if name == \"Mamdani\" else 0.5\n",
    "        preds = (s >= thres).astype(int)\n",
    "\n",
    "        m = final_report[\"metrics\"][name]\n",
    "        m['auc'].append(roc_auc_score(y_f_val, s))\n",
    "        m['f1'].append(f1_score(y_f_val, preds))\n",
    "        m['prec'].append(precision_score(y_f_val, preds, zero_division=0))\n",
