   "cell_type": "markdown",
   "source": "# Definition der FIS-Hilfsfunktionen",
   "id": "15af3b0f4a4f7fc1"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-27T15:40:54.013232Z",
     "start_time": "2026-03-27T15:40:53.993539Z"
    }
   },
   "cell_type": "code",
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import simpful as sf\n",
    "from sklearn.linear_model import LinearRegression # Besser für TSK-1 Scores als LogReg\n",
    "\n",
    "# 1. Optimierte TSK-1 Gleichungs-Generierung\n",
    "def get_tsk1_equation(df_subset, feature_names):\n",
    "    \"\"\"\n",
    "    Erzeugt eine lineare Regressionsgleichung für TSK-1.\n",
    "    Wir nutzen LinearRegression, da FIS-Outputs kontinuierliche Scores sind.\n",
    "    \"\"\"\n",
    "    # Sicherheitscheck: Mindestens 5 Samples und Varianz in den Daten nötig\n",
    "    if len(df_subset) < 5 or df_subset['cartel'].std() == 0:\n",
    "        val = df_subset['cartel'].mean() if not df_subset.empty else 0.5\n",
    "        return f\"{val:.6f}\"\n",
    "\n",
    "    # Modell fit (Linear statt Logistisch für weichere Scores)\n",
    "    model = LinearRegression().fit(df_subset[feature_names], df_subset['cartel'])\n",
    "\n",
    "    combined_coeffs = np.append(model.intercept_, model.coef_)\n",
    "    tsk1_coeffs_collector[f\"f{i}\"].append(combined_coeffs)\n",
    "\n",
    "    # Terme generieren: w1*x1 + w2*x2 ...\n",
    "    terms = [f\"{coef:.6f}*{name}\" for coef, name in zip(model.coef_, feature_names)]\n",
    "    equation = \" + \".join(terms) + f\" + {model.intercept_:.6f}\"\n",
    "\n",
    "    # Simpful evaluiert Strings - wir müssen sicherstellen, dass keine ungültigen Zeichen drin sind\n",
    "    return equation\n",
    "\n",
    "# 2. Definition der Fuzzy-Variablen (Membership Functions)\n",
    "def setup_simpful_vars(FS):\n",
    "    # CV: Trapezförmige MFs für weiche Übergänge\n",
    "    cv_low = sf.FuzzySet(points=[[0, 1], [0.04, 1], [0.052, 0]], term=\"Niedrig\")\n",
    "    cv_middle = sf.FuzzySet(points=[[0.046,0], [0.052, 1], [0.06, 0]], term=\"Mittel\")\n",
    "    cv_high = sf.FuzzySet(points=[[0.055, 0], [0.14, 1], [0.4, 1]], term=\"Hoch\")\n",
    "    FS.add_linguistic_variable(\"cv\", sf.LinguisticVariable([cv_low,cv_middle, cv_high], universe_of_discourse=[0, 0.4]))\n",
    "\n",
    "    # SPREAD: Überlappung bei 0.15-0.20 verhindert Logik-Löcher\n",
    "    spread_low = sf.FuzzySet(points=[[0, 1], [0.12, 1], [0.18, 0]], term=\"Niedrig\")\n",
    "    spread_middle = sf.FuzzySet(points=[[0.12, 0], [0.18, 1], [0.24, 0]], term=\"Mittel\")\n",
    "    spread_high = sf.FuzzySet(points=[[0.18, 0], [0.24, 1], [0.9, 1]], term=\"Hoch\")\n",
    "    FS.add_linguistic_variable(\"spread\", sf.LinguisticVariable([spread_low,spread_middle, spread_high], universe_of_discourse=[0, 0.9]))\n",
    "\n",
    "    # RD: Skalierung auf den Bereich 0-10\n",
    "    rd_low = sf.FuzzySet(points=[[0, 1], [1.5, 1], [3.0, 0]], term=\"Niedrig\")\n",
    "    rd_high = sf.FuzzySet(points=[[2.0, 0], [4.0, 1], [10, 1]], term=\"Hoch\")\n",
    "    FS.add_linguistic_variable(\"rd\", sf.LinguisticVariable([rd_low, rd_high], universe_of_discourse=[0, 10]))\n",
    "\n",
    "    # SKEW: Fokus auf negative Schiefe (typisch für Kartelle)\n",
    "    skew_neg = sf.FuzzySet(points=[[-3, 1], [-0.5, 1], [0.1, 0]], term=\"Negativ\")\n",
    "    skew_pos = sf.FuzzySet(points=[[-0.1, 0], [0.5, 1], [3, 1]], term=\"Positiv\")\n",
    "    FS.add_linguistic_variable(\"skew\", sf.LinguisticVariable([skew_neg, skew_pos], universe_of_discourse=[-3, 3]))\n",
    "\n",
    "    # DIFFP: Einseitiger Trigger für hohe Preisdifferenzen\n",
    "    diffp_low = sf.FuzzySet(points=[[0, 1], [0.034, 0]], term=\"Niedrig\")\n",
    "    diffp_middle = sf.FuzzySet(points=[[0.03, 0], [0.034, 1], [0.042, 0]], term=\"Mittel\")\n",
    "    diffp_high = sf.FuzzySet(points=[[0.034, 0], [0.55, 1]], term=\"Hoch\")\n",
    "    FS.add_linguistic_variable(\"diffp\", sf.LinguisticVariable([diffp_high], universe_of_discourse=[0, 0.55]))\n",
    "\n",
    "# 3. Die 7 Expertenregeln (Einheitlich für TSK-0 und TSK-1)\n",
    "tsk_rules = [\n",
    "    \"IF (cv IS Niedrig) AND (spread IS Niedrig) THEN (suspiciousness IS f1)\",\n",
    "    \"IF (cv IS Niedrig) AND (diffp IS Hoch) THEN (suspiciousness IS f2)\",\n",
    "    \"IF (cv IS Niedrig) THEN (suspiciousness IS f3)\",\n",
    "    \"IF (cv IS Niedrig) AND (rd IS Hoch) THEN (suspiciousness IS f4)\",\n",
    "    \"IF (rd IS Hoch) AND (skew IS Negativ) THEN (suspiciousness IS f5)\",\n",
    "    \"IF (cv IS Hoch) AND (spread IS Hoch) THEN (suspiciousness IS f6)\",\n",
    "    \"IF (rd IS Niedrig) AND (spread IS Niedrig) THEN (suspiciousness IS f7)\"\n",
    "]\n",
    "\n",
    "# --- 4. Definition des Mamdani-Systems (skfuzzy) ---\n",
    "\n",
    "# Antezedenzien (Inputs)\n",
    "cv = ctrl.Antecedent(np.arange(0, 0.4, 0.001), 'cv')\n",
    "spread = ctrl.Antecedent(np.arange(0, 0.9, 0.01), 'spread')\n",
    "rd = ctrl.Antecedent(np.arange(0, 10, 0.1), 'rd')\n",
    "skew = ctrl.Antecedent(np.arange(-3, 3, 0.01), 'skew')\n",
    "diffp = ctrl.Antecedent(np.arange(0, 0.55, 0.001), 'diffp')\n",
    "\n",
    "# Konsequent (Output - 0 bis 100)\n",
    "verdacht = ctrl.Consequent(np.arange(0, 101, 1), 'Verdächtigkeitsscore')\n",
    "\n",
    "# Membership Functions (Synchron mit Simpful Logik)\n",
    "cv['Niedrig'] = fuzz.trapmf(cv.universe, [0, 0, 0.04, 0.052])\n",
    "cv['Mittel'] = fuzz.trimf(cv.universe, [0.046, 0.052, 0.06])\n",
    "cv['Hoch'] = fuzz.trapmf(cv.universe, [0.05, 0.12, 0.4, 0.4])\n",
    "\n",
    "spread['Niedrig'] = fuzz.trapmf(spread.universe, [0, 0, 0.08, 0.13])\n",
    "spread['Mittel'] = fuzz.trimf(spread.universe, [0.08, 0.13, 0.21])\n",
    "spread['Hoch'] = fuzz.trapmf(spread.universe, [0.13, 0.21, 0.9, 0.9])\n",
    "\n",
    "rd['Niedrig'] = fuzz.trapmf(rd.universe, [0, 0, 1.5, 3.0])\n",
    "rd['Hoch'] = fuzz.trapmf(rd.universe, [2.0, 4.0, 10, 10])\n",
    "\n",
    "skew['Negativ'] = fuzz.trapmf(skew.universe, [-3, -3, -0.5, 0.1])\n",
    "skew['Positiv'] = fuzz.trapmf(skew.universe, [-0.1, 0.5, 3, 3])\n",
    "\n",
    "diffp['Niedrig'] = fuzz.trapmf(diffp.universe, [0, 0, 0.017, 0.037])\n",
    "diffp['Mittel'] = fuzz.trimf(diffp.universe, [0.017, 0.037, 0.062])\n",
    "diffp['Hoch'] = fuzz.trapmf(diffp.universe, [0.062, 0.12, 0.55, 0.55])\n",
    "\n",
    "# Output MFs für Mamdani\n",
    "verdacht['Niedrig'] = fuzz.trimf(verdacht.universe, [0, 0, 50])\n",
    "verdacht['Mittel'] = fuzz.trimf(verdacht.universe, [0, 50, 100])\n",
    "verdacht['Hoch'] = fuzz.trimf(verdacht.universe, [50, 100, 100])\n",
    "\n",
    "# Mamdani Regeln (Logisch identisch mit TSK)\n",
    "m_rules = [\n",
    "    ctrl.Rule(cv['Niedrig'] & spread['Niedrig'], verdacht['Hoch']),\n",
    "    ctrl.Rule(cv['Niedrig'] & diffp['Hoch'], verdacht['Hoch']),\n",
    "    ctrl.Rule(cv['Niedrig'], verdacht['Hoch']), # Basis-Verdacht\n",
    "    ctrl.Rule(cv['Niedrig'] & rd['Hoch'], verdacht['Hoch']),\n",
    "    ctrl.Rule(rd['Hoch'] & skew['Negativ'], verdacht['Hoch']),\n",
    "    ctrl.Rule(cv['Hoch'] & spread['Hoch'], verdacht['Niedrig']), # Kontrollregel\n",
    "    ctrl.Rule(rd['Niedrig'] & spread['Niedrig'], verdacht['Mittel'])\n",
    "]\n",
    "\n",
    "# System und Simulation erstellen\n",
    "mamdani_ctrl = ctrl.ControlSystem(m_rules)\n",
    "mamdani_sim = ctrl.ControlSystemSimulation(mamdani_ctrl)"
   ],
   "id": "f97b6e234184024f",
   "outputs": [],
   "execution_count": 3
